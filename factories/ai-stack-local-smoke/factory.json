{
  "factoryId": "ai-stack-local-smoke",
  "version": "v1",
  "summary": "First-factory cell wrapping ai-stack.local-smoke-nightly. Concrete-first; do not generalize.",
  "objective": "Keep ai-stack.local-smoke-nightly healthy.",
  "lane": {
    "launchdLabel": "com.andre.ai-stack.local-smoke",
    "launchdPlist": "/Users/test/Library/LaunchAgents/com.andre.ai-stack.local-smoke.plist",
    "verifierEntry": "/Users/test/bin/ai-stack-local-smoke-nightly",
    "verifierImpl": "/Users/test/bin/ai-stack-local-smoke",
    "underlyingTool": [
      "/Users/test/frontier-os/bin/frontier",
      "mcp",
      "smoke",
      "--read-only"
    ],
    "logs": {
      "out": "/Users/test/Library/Logs/AIStack/local-smoke-agent.out.log",
      "err": "/Users/test/Library/Logs/AIStack/local-smoke-agent.err.log"
    }
  },
  "policy": {
    "approvalClass": 1,
    "allowedActions": [
      "run-verifier",
      "capture-evidence",
      "verify-timeout-config",
      "write-ledger-entry",
      "emit-alert"
    ],
    "forbiddenActions": [
      "broad-refactor",
      "ui-changes",
      "destructive-cleanup",
      "force-push",
      "delete-evidence",
      "modify-siri-or-menubar",
      "rename-screenshots-or-readme-links"
    ],
    "killSwitchFile": "factories/ai-stack-local-smoke/state/disabled",
    "escalation": [
      "ambiguous-result",
      "repair-did-not-clear-failure",
      "missing-evidence",
      "kill-switch-active",
      "dirty-working-tree-not-from-this-session"
    ]
  },
  "classification": {
    "passed": "verifier exit=0 AND stdout is JSON AND payload.failed == 0",
    "failed": "verifier exit!=0 OR (JSON parse OK AND payload.failed > 0)",
    "ambiguous": "exit=0 with non-JSON output, OR JSON parse failure with exit=0, OR timeout, OR file-not-found"
  },
  "boundedRepair": {
    "kind": "verify-timeout-config",
    "description": "Read-only check that the live smoke script's subprocess timeout for `frontier mcp smoke --read-only` is at least 60s. The 2026-04-25T07:55Z failure was a 30s subprocess.TimeoutExpired; commit a623dd6 in /Users/test bumped it to 60s. The repair *verifies the bump landed*; it does not modify files.",
    "target": "/Users/test/bin/ai-stack-local-smoke",
    "minTimeoutSeconds": 60,
    "destructive": false,
    "rollback": "no-op (read-only)"
  },
  "ledger": {
    "sessionLabel": "factory:ai-stack-local-smoke",
    "actor": "factory.ai-stack-local-smoke",
    "events": ["system", "ops.repair_start", "ops.repair_end", "alert"]
  },
  "alert": {
    "source": "factory.ai-stack-local-smoke",
    "category": "health",
    "severityByClassification": {
      "passed": null,
      "failed": "high",
      "ambiguous": "medium"
    }
  }
}
