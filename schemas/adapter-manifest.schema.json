{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontier-os.local/schemas/adapter-manifest.schema.json",
  "title": "FrontierOS Adapter Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adapterId",
    "version",
    "displayName",
    "owner",
    "transport",
    "modes",
    "commands"
  ],
  "properties": {
    "adapterId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "transport": {
      "type": "string",
      "enum": [
        "native_cli",
        "http_api",
        "cdp",
        "apple_automation",
        "shell",
        "composite"
      ]
    },
    "modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["read", "propose", "apply", "undo"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "approvalDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultClass": {
          "type": "integer",
          "enum": [0, 1, 2, 3]
        },
        "billableClass": {
          "type": "integer",
          "enum": [0, 1, 2, 3]
        },
        "destructiveClass": {
          "type": "integer",
          "enum": [0, 1, 2, 3]
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "summary",
          "supportedModes",
          "sideEffectClass",
          "verifierHints"
        ],
        "properties": {
          "command": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "supportedModes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["read", "propose", "apply", "undo"]
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "sideEffectClass": {
            "type": "string",
            "enum": [
              "auth_change",
              "billable_action",
              "deploy",
              "destructive_action",
              "external_message",
              "financial_action",
              "local_write",
              "none",
              "pr_open",
              "repo_write",
              "shared_write",
              "ticket_write"
            ]
          },
          "verifierHints": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "undoSupported": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}
