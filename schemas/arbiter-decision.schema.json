{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontier-os.local/schemas/arbiter-decision.schema.json",
  "title": "FrontierOS Arbiter Decision",
  "description": "Output of the merge arbiter. Consumed by an operator (no auto-merge in v1) to decide whether to apply a builder swarm candidate. Captures the decision, the evidence behind it, and the verification re-run that produced ground truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decisionId",
    "scannedAt",
    "taskId",
    "decision",
    "evidence",
    "candidatesEvaluated",
    "rerunVerification",
    "rubricScores",
    "antiExampleMatches"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "decisionId": { "type": "string", "minLength": 1 },
    "scannedAt": { "type": "string", "format": "date-time" },
    "taskId": { "type": "string", "minLength": 1 },
    "packetId": { "type": "string" },
    "decision": {
      "enum": ["accept", "combine", "reject", "escalate_to_human"]
    },
    "selectedBuilderId": { "type": "string" },
    "combineInstructions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rejectionReasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "escalationQuestion": { "type": "string" },
    "qualityFloor": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "candidatesEvaluated": { "type": "integer", "minimum": 0 },
    "rerunVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["builderIds", "results"],
      "properties": {
        "builderIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "results": {
          "type": "array",
          "items": { "$ref": "#/$defs/verificationResult" }
        }
      }
    },
    "rubricScores": {
      "type": "array",
      "items": { "$ref": "#/$defs/rubricScore" }
    },
    "antiExampleMatches": {
      "type": "array",
      "items": { "$ref": "#/$defs/antiExampleMatch" }
    },
    "evidence": {
      "type": "string",
      "minLength": 1,
      "description": "Operator reads this first — bury nothing."
    },
    "elapsedMs": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "verificationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["builderId", "ranAt", "phase"],
      "properties": {
        "builderId": { "type": "string" },
        "worktreePath": { "type": "string" },
        "phase": {
          "enum": [
            "skipped",
            "worktree_missing",
            "typecheck_failed",
            "tests_failed",
            "passed_typecheck_only",
            "passed"
          ]
        },
        "typecheckExitCode": { "type": "integer" },
        "testExitCode": { "type": "integer" },
        "typecheckStderr": { "type": "string" },
        "testStderr": { "type": "string" },
        "ranAt": { "type": "string", "format": "date-time" },
        "elapsedMs": { "type": "integer", "minimum": 0 }
      }
    },
    "rubricScore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "builderId",
        "rubricId",
        "score",
        "scoredWeight",
        "totalWeight",
        "coverage",
        "unsupportedCriteria",
        "criteria"
      ],
      "properties": {
        "builderId": { "type": "string" },
        "rubricId": { "type": "string" },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Weighted aggregate over scored (non-null) criteria. MUST be read alongside coverage — score=1.0 with coverage=0.1 means one criterion of ten was actually scored."
        },
        "scoredWeight": {
          "type": "number",
          "minimum": 0,
          "description": "Sum of weights for criteria that returned a non-null score."
        },
        "totalWeight": {
          "type": "number",
          "minimum": 0,
          "description": "Sum of weights across all criteria in the rubric."
        },
        "coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "scoredWeight / totalWeight. Arbiter requires this is at or above minRubricCoverage before treating score as trustworthy. (GPT Pro Issue #3.)"
        },
        "unsupportedCriteria": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of criteria that returned score=null (heuristic could not fire). Surfaced so the operator sees which dimensions were not assessed."
        },
        "criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/criterionScore" }
        }
      }
    },
    "criterionScore": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "score", "rationale"],
      "properties": {
        "id": { "type": "string" },
        "score": {
          "anyOf": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "type": "null" }
          ],
          "description": "null when this criterion can't be scored heuristically and no LLM judge ran."
        },
        "weight": { "type": "number", "minimum": 0 },
        "rationale": { "type": "string" }
      }
    },
    "antiExampleMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["builderId", "antiExample", "verdict"],
      "properties": {
        "builderId": { "type": "string" },
        "antiExample": { "type": "string" },
        "verdict": { "enum": ["matches", "safe", "unsure"] },
        "evidence": { "type": "string" }
      }
    }
  }
}
