{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontier-os.local/schemas/memory-record.schema.json",
  "title": "FrontierOS Memory Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "memoryId",
    "version",
    "recordedAt",
    "memoryType",
    "summary",
    "scope",
    "evidence"
  ],
  "properties": {
    "memoryId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "memoryType": {
      "type": "string",
      "enum": [
        "episodic",
        "procedural",
        "outcome",
        "cross_project",
        "system_health"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project": {
          "type": "string"
        },
        "systems": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "traceId": {
          "type": "string"
        },
        "graphId": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "ref"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "trace",
              "file",
              "screenshot",
              "metric",
              "api_response",
              "command_output"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "lessons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "heuristics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
