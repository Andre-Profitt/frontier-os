{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontier-os.local/schemas/model-routing-policy.schema.json",
  "title": "FrontierOS Model Routing Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policyId",
    "version",
    "defaults",
    "routes"
  ],
  "properties": {
    "policyId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preferredExecutor",
        "fallbackExecutors"
      ],
      "properties": {
        "preferredExecutor": {
          "type": "string",
          "minLength": 1
        },
        "fallbackExecutors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "match",
          "preferredExecutor"
        ],
        "properties": {
          "match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "taskKinds": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "uniqueItems": true
              },
              "systems": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "uniqueItems": true
              },
              "labels": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "uniqueItems": true
              }
            }
          },
          "preferredExecutor": {
            "type": "string",
            "minLength": 1
          },
          "fallbackExecutors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
