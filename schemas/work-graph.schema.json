{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontier-os.local/schemas/work-graph.schema.json",
  "title": "FrontierOS Work Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "graphId",
    "version",
    "goal",
    "tenantId",
    "createdAt",
    "priority",
    "status",
    "approvalPolicy",
    "nodes"
  ],
  "properties": {
    "graphId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "tenantId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "urgent"]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "planned",
        "running",
        "blocked",
        "awaiting_approval",
        "completed",
        "failed",
        "canceled"
      ]
    },
    "approvalPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultClass", "requireHumanFor"],
      "properties": {
        "defaultClass": {
          "type": "integer",
          "enum": [0, 1, 2, 3]
        },
        "requireHumanFor": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "auth_change",
              "billable_action",
              "data_deletion",
              "deploy",
              "destructive_action",
              "external_message",
              "financial_action",
              "prod_write",
              "security_change"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxRuntimeSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "maxInputTokens": {
          "type": "integer",
          "minimum": 1
        },
        "maxOutputTokens": {
          "type": "integer",
          "minimum": 1
        },
        "maxToolCalls": {
          "type": "integer",
          "minimum": 0
        },
        "maxCostUsd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "entryIntent": {
      "$ref": "#/$defs/intentRef"
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "successCriteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodeId",
        "kind",
        "title",
        "status",
        "priority",
        "runtime",
        "approvalClass",
        "dependencies",
        "allowedTools",
        "verifierPolicy",
        "inputs"
      ],
      "properties": {
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "research",
            "repo_analysis",
            "code_change",
            "test_run",
            "review",
            "approval",
            "browser_task",
            "mac_task",
            "incident_packet",
            "document_generation",
            "publish",
            "dispatch"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "blocked",
            "awaiting_approval",
            "completed",
            "failed",
            "skipped",
            "canceled"
          ]
        },
        "priority": {
          "type": "string",
          "enum": ["low", "normal", "high", "urgent"]
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["plane", "executor"],
          "properties": {
            "plane": {
              "type": "string",
              "enum": ["linux", "mac", "browser", "remote_api"]
            },
            "executor": {
              "type": "string",
              "enum": [
                "codex_app_server",
                "codex_exec",
                "claude_code",
                "native_cli",
                "mcp_tool",
                "playwright",
                "custom_worker"
              ]
            },
            "model": {
              "type": "string"
            },
            "worktreeStrategy": {
              "type": "string",
              "enum": ["none", "shared", "isolated"]
            }
          }
        },
        "approvalClass": {
          "type": "integer",
          "enum": [0, 1, 2, 3]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "allowedTools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "verifierPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["none", "required", "required_before_side_effect"]
            },
            "checks": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "tests",
                  "lint",
                  "policy",
                  "trace_grade",
                  "artifact_schema",
                  "human_review"
                ]
              },
              "uniqueItems": true
            },
            "config": {
              "type": "object",
              "additionalProperties": true,
              "description": "Per-check configuration. Keys match check names in `checks`. See src/work/verifier.ts for the accepted shapes."
            }
          }
        },
        "budgets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxRuntimeSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "maxInputTokens": {
              "type": "integer",
              "minimum": 1
            },
            "maxOutputTokens": {
              "type": "integer",
              "minimum": 1
            },
            "maxToolCalls": {
              "type": "integer",
              "minimum": 0
            },
            "maxCostUsd": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "retryPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxAttempts"],
          "properties": {
            "maxAttempts": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            },
            "backoffMs": {
              "type": "integer",
              "minimum": 0
            },
            "retryOnFailed": {
              "type": "boolean"
            }
          }
        },
        "sideEffects": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "auth_change",
              "billable_action",
              "deploy",
              "destructive_action",
              "external_message",
              "financial_action",
              "local_write",
              "none",
              "pr_open",
              "repo_write",
              "shared_write",
              "ticket_write"
            ]
          },
          "uniqueItems": true
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/output"
          }
        },
        "owner": {
          "type": "string"
        },
        "originIntentRef": {
          "$ref": "#/$defs/intentRef"
        },
        "traceId": {
          "type": "string"
        }
      }
    },
    "intentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intentId", "intentType", "surfaceChannel"],
      "properties": {
        "intentId": {
          "type": "string",
          "minLength": 1
        },
        "intentType": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
        },
        "surfaceChannel": {
          "type": "string",
          "enum": [
            "cli",
            "siri_shortcut",
            "apple_app_intent",
            "mobile_app",
            "menu_bar",
            "web",
            "api",
            "automation"
          ]
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "text",
            "url",
            "repo_ref",
            "ticket_ref",
            "file_ref",
            "artifact_ref",
            "structured_payload"
          ]
        },
        "value": {}
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "location"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "report",
            "patch",
            "branch",
            "log",
            "test_result",
            "review_result",
            "artifact",
            "dispatch_record"
          ]
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        }
      }
    }
  }
}
