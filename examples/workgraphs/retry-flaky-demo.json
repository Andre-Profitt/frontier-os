      "approvalClass": 0,
      "dependencies": ["flaky"],
      "allowedTools": ["echo"],
      "verifierPolicy": { "mode": "none" },
      "inputs": [
        {
          "type": "structured_payload",
          "value": {
            "cli": { "command": "/bin/echo", "args": ["retry path verified"] }
          }
        }
      ]
    }
  ]
