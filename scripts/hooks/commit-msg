#!/usr/bin/env bash
# commit-msg — Phase 4 agent commit guard.
#
# Enforces that agent-authored commits include three audit fields in the
# commit message body:
#
#   Session: <agent session id>
#   Scope: <what this commit covers>
#   Verification: <exact commands run>
#
# Bypass surface (visible only — auditability requires that any bypass leave
# a marker in the commit history):
#
#   - prefix the commit subject with `[no-guard]` for explicit human /
#     emergency override
#   - merge commits (subject begins with `Merge `) are exempt because Git
#     generates the message; the merged branch commits should already
#     carry audit metadata
#
# NO env-var bypass exists. Revert / fixup! / squash! / amend! commits are
# NOT auto-exempt — they are still authored commits and must include the
# three fields, or use the visible `[no-guard]` prefix.
#
# Exit codes:
#   0  message accepted
#   1  message rejected (missing required fields)

set -euo pipefail

MSG_FILE="${1:-}"
if [[ -z "$MSG_FILE" || ! -f "$MSG_FILE" ]]; then
  echo "commit-msg guard: no message file provided" >&2
  exit 1
fi

# Strip git-comment lines (those starting with #) before inspecting. Use a
# temp variable to avoid relying on bash >=4 readarray availability.
MSG_BODY="$(sed -e '/^#/d' "$MSG_FILE")"

# Visible bypass via subject prefix.
SUBJECT="$(printf '%s' "$MSG_BODY" | sed -n '1p')"
if [[ "$SUBJECT" == \[no-guard\]* ]]; then
  exit 0
fi

# Auto-exempt only Git-generated merge messages.
if [[ "$SUBJECT" =~ ^Merge\  ]]; then
  exit 0
fi

# Validate each required field has a non-empty value.
# Match `^Field:\s*<at least one non-space character>` line-anchored,
# case-sensitive.
require_field() {
  local field="$1"
  if ! printf '%s\n' "$MSG_BODY" | grep -Eq "^${field}:[[:space:]]*[^[:space:]]+"; then
    return 1
  fi
  return 0
}

MISSING=()
for field in Session Scope Verification; do
  if ! require_field "$field"; then
    MISSING+=("$field")
  fi
done

if [[ ${#MISSING[@]} -gt 0 ]]; then
  cat >&2 <<EOF
commit-msg guard: rejected — missing required field(s): ${MISSING[*]}

Agent commits must include the three audit lines in the message body:

  Session: <agent session id>
  Scope: <what this commit covers>
  Verification: <exact commands run>

Example:

  feat(eval): add factory quality eval suite

  Session: claude-factory-quality-eval-2026-04-26
  Scope: Phase 3 eval suite for local-smoke factory quality
  Verification: npm run typecheck; node --import tsx --test evals/factory-quality/tests/quality.test.ts

Bypass (visible only):
  - prefix subject with [no-guard]
  - merge commits (subject begins with "Merge ") are exempt automatically

Revert / fixup! / squash! / amend! commits are NOT auto-exempt — they
must include the three fields, or use the [no-guard] prefix.

Re-stage your changes after amending the message and try again.
EOF
  exit 1
fi

exit 0
